import requests, json

def emotion_detector(text_to_analyse):
    url = 'https://sn-watson-emotion.labs.skills.network/v1/watson.runtime.nlp.v1/NlpService/EmotionPredict'
    header = {"grpc-metadata-mm-model-id": "emotion_aggregated-workflow_lang_en_stock"}
    input_obj = { "raw_document": { "text": text_to_analyse } }

    response = requests.post(url, json=input_obj, headers=header)

    if response.status_code == 200:
        formated_response = json.loads(response.text)
        return formated_response['emotionPredictions'][0]['emotion']
    
    if response.status_code == 400:
        data = {
                "anger": None,
                "disgust": None,
                "fear": None,
                "joy": None,
                "sadness": None
            }
        return data

    return "failed to process"

def get_dominant_emotion(emotions):
    dominant_emotion = None
    value = None
    for e, v in emotions.items():
        if dominant_emotion is None or v > value:
            dominant_emotion = e
            value = v
    return dominant_emotion